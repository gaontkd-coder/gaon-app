          <Field label="상태">
            <select style={{ ...inp, opacity: isProtected(edit) ? 0.5 : 1 }} value={edit.status || "활동중"} disabled={isProtected(edit)} onChange={(e) => setEdit({ ...edit, status: e.target.value })}>
